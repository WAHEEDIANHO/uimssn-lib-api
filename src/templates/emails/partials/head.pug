
doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= `MSSNUI Library - ${action}`
    style.
      body {
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f4f4f4;
      }
      .container {
        background-color: #ffffff;
        max-width: 600px;
        margin: auto;
        border-radius: 8px;
        overflow: hidden;
      }
      .header {
        padding: 20px;
        text-align: center;
        background: #ffffff;
      }
      .header img {
        width: 140px;
      }
      .hero {
        position: relative;
        text-align: center;
        color: white;
      }
      .hero-img {
        width: 100%;
        display: block;
      }
      .button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: #ffffff;
        color: #1d3557;
        padding: 12px 20px;
        font-weight: bold;
        border-radius: 6px;
        text-decoration: none;
      }
      .content {
        padding: 30px 20px;
        color: #333;
      }
      .otp-link a {
        color: #ff00aa;
        font-family: monospace;
      }
      .otp-code {
        font-size: 24px;
        font-weight: bold;
        color: #1d3557;
        text-align: center;
        padding: 20px;
        background-color: #f8f9fa;
        border-radius: 8px;
        margin: 20px 0;
        font-family: 'Courier New', monospace;
        letter-spacing: 2px;
      }
      .footer {
        background-color: #003366;
        color: white;
        text-align: center;
        padding: 20px;
      }
      .footer a {
        color: #a5f3fc;
        text-decoration: none;
      }
      .social-icons img {
        width: 24px;
        margin: 0 10px;
      }
